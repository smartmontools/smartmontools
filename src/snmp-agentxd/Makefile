	  echo " $(MKDIR_P) '$(DESTDIR)$(smartmonconfdir)'"; \
	  $(MKDIR_P) "$(DESTDIR)$(smartmonconfdir)" || exit 1; \
	fi; \
	for p in $$list; do \
	  if test -f "$$p"; then d=; else d="$(srcdir)/"; fi; \
	  echo "$$d$$p"; \
	done | $(am__base_list) | \
	while read files; do \
	  echo " $(INSTALL_DATA) $$files '$(DESTDIR)$(smartmonconfdir)'"; \
	  $(INSTALL_DATA) $$files "$(DESTDIR)$(smartmonconfdir)" || exit $$?; \
	done

